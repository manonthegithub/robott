# Copy to .env and fill in for your wiring. Not read in production
# (systemd unit should set real env vars instead) - see README/docs/progress.md.

# Required - find via `gpiodetect` / `gpioinfo` (apt install gpiod)
GPIO_CHIP=gpiochip4
LED_OFFSET=17
STEPPER_STEP_OFFSET=27
STEPPER_DIR_OFFSET=22
SERVO_CHIP_PATH=/sys/class/pwm/pwmchip0
SERVO_CHANNEL=0

# Optional - defaults shown
# LISTEN_ADDR=:8080
# QUEUE_CAPACITY=32
# STEPPER_PULSE_DELAY_US=1000
# SERVO_MIN_ANGLE=0
# SERVO_MAX_ANGLE=180
